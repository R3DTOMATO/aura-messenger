# MySQL connection string
DATABASE_URL=mysql://root:password@localhost:3306/aura_messenger

# JWT signing secret (long random string)
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Optional: email of user to auto-promote to admin on register
OWNER_EMAIL=

# Optional: server port (default 3000)
PORT=3000

# ── Firebase Cloud Storage ────────────────────────────────────
# Find your bucket name in Firebase Console → Storage (e.g. my-app.appspot.com)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Path to your service account key JSON (download from Firebase Console → Settings → Service accounts)
# Keep this file OUT of git (it's already in .gitignore by default)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-key.json

# Alternative: paste the entire JSON content as a single line (useful for hosting platforms)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
